ans( X, Y, Z, W, U )?
p(1..5, 1..5).
q(1..5, 10..14).
r(10..14, 100..104).
s(100..104, 1000..1004).
t(1..5, 2..6).

j1( X, Y, Z ) :- p( X, Y ), q( Y, Z ), X < Y, Z > 10.
j2( Z, W )    :- r( Z, W ), W != 102.
j3( W, U )    :- s( W, U ), U > W * 9.
ans( X, Y, Z, W, U ) :- j1( X, Y, Z ), j2( Z, W ), j3( W, U ), t( X, Y2 ), Y2 > Y.
