
u(1..3, 10..12, 100..102).
v(100..102, "ix").
v(103, "drop").
w(10..12).

s("a","A",1).
s("b","B",2).
s("c","A",3).
t("A", "ok").
t("B", "nope").

x(1000,1). x(2000,2). x(3000,3).


%Rule 1: 4-way join on non-leading attributes + filters
out1( K, V, T ) :-
  u( K, M, V ),
  v( V, T ),
  w( M ),
  x( Z, M ),
  Z > 1500, M != 1.

% Rule 2: strings branch, 3-way join, filters
out2( K, V, T ) :-
  s( K, V, R ),
  t( V, T ),
  x( Z, R ),
  T = "ok", Z >= 2000.

% Rule 3: integers fallback with stricter arithmetic predicate
okv( V ) :- v( V, _ ).
out3( K, V, "tight" ) :-
  u( K, M, V ),
  okv( V ),
  x( Z, M ),
  Z > V * 9, M > 1.
