a1(1..5, 100..104, 1000..1004).
a2(100..104, 7..9).
a3(7..9, 70..90).
a4(1000..1004).
a5(1..5, 1..5).

% Helper filters
fy( Y ) :- a2( Y, _ ).   % even Y in 100..104
fw( W ) :- a3( W, _ ), W > 7.                % W ∈ {8,9}

% Projected join fragments
jA( X, Y, Z ) :- a1( X, Y, Z ), fy( Y ), Z > 1000.
jB( Y, W )    :- a2( Y, W ), fw( W ).
jC( W, U )    :- a3( W, U ), U >= W * 10.    % for W=8 → U∈[80..90], W=9 → U=90
jD( Z )       :- a4( Z ).
jE( X, T )    :- a5( X, T ), T < X + 2.

% Long head rule (5 joins) + arithmetic (relaxed to be feasible)
ans3( X, Y, Z, W, U ) :-
  jA( X, Y, Z ),
  jB( Y, W ),
  jC( W, U ),
  jD( Z ),
  jE( X, T ),
  U + 950 > Z, T != 0.
