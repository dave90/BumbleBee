SELECT c1."LAST NAME" as LAST_NAME, c1."FIRST NAME" as FIRST_NAME, c1.USERNAME as USERNAME, c1.IDENTIFIER as IDENTIFIER
FROM "./files/csv/username.csv" as c1
WHERE c1.IDENTIFIER > 10 AND c1."LAST NAME" > 'A' OR c1."FIRST NAME" < 'Z' AND c1.USERNAME = 'guest' OR c1."LAST NAME" = 'Doe' AND c1."FIRST NAME" = 'Jane' OR c1.USERNAME > 'admin' AND c1.IDENTIFIER < 500
