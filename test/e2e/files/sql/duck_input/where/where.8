SELECT c1."LAST NAME" as LAST_NAME, c1."FIRST NAME" as FIRST_NAME, c1.USERNAME as USERNAME, c1.IDENTIFIER as IDENTIFIER
FROM './files/csv/username.csv' as c1
WHERE c1."LAST NAME" = 'Smith' OR c1."FIRST NAME" = 'John' AND c1.USERNAME > 'A' OR c1.IDENTIFIER < 100 AND c1."LAST NAME" < 'M' OR c1."FIRST NAME" > 'B' AND c1.USERNAME < 'Z'
