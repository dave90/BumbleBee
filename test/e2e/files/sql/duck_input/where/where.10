SELECT c1."LAST NAME" as LAST_NAME, c1."FIRST NAME" as FIRST_NAME, c1.USERNAME as USERNAME, c1.IDENTIFIER as IDENTIFIER
FROM './files/csv/username.csv' as c1
WHERE c1."LAST NAME" <> 'Brown' AND c1."FIRST NAME" <> 'Alice' OR c1.USERNAME = 'root' AND c1.IDENTIFIER > 100 OR c1."LAST NAME" < 'Z' AND c1."FIRST NAME" > 'A' OR c1.USERNAME < 'user' AND c1.IDENTIFIER = 42 OR c1."LAST NAME" = 'White'
