SELECT COUNT(*) AS cnt
FROM './files/parquet/tpch/lineitem.parquet' l,
     './files/parquet/tpch/part.parquet' p
WHERE (p.p_partkey = l.l_partkey AND p.p_brand = 'Brand#12' AND p.p_container IN ('SM CASE', 'SM BOX', 'SM PACK', 'SM PKG') AND l.l_shipmode IN ('AIR', 'AIR REG'))
   OR (p.p_partkey = l.l_partkey AND p.p_brand = 'Brand#23' AND p.p_container IN ('MED BAG', 'MED BOX', 'MED PKG', 'MED PACK') AND l.l_shipmode IN ('AIR', 'AIR REG'))
   OR (p.p_partkey = l.l_partkey AND p.p_brand = 'Brand#34' AND p.p_container IN ('LG CASE', 'LG BOX', 'LG PACK', 'LG PKG') AND l.l_shipmode IN ('AIR', 'AIR REG'))