%@sql
SELECT L_COMMENT, L_SHIPMODE, L_RECEIPTDATE, L_SHIPDATE, L_RETURNFLAG, L_LINESTATUS, L_COMMITDATE, L_DISCOUNT, L_SUPPKEY, L_PARTKEY, L_EXTENDEDPRICE, L_QUANTITY, L_TAX, L_SHIPINSTRUCT, L_LINENUMBER, L_ORDERKEY
FROM "./files/csv/tpch/lineitem_2.csv"
WHERE L_ORDERKEY = 484549 OR L_QUANTITY > 1 AND L_DISCOUNT < 0.1 OR L_TAX > 0.0 AND L_SHIPMODE = "AIR" OR L_RETURNFLAG = "N" AND L_LINESTATUS = "O"
