%@sql
SELECT c1.LAST_NAME, c1.FIRST_NAME, c1.USERNAME, c1.IDENTIFIER
FROM "./files/csv/username.csv" as c1
WHERE c1.IDENTIFIER > 10 AND c1.LAST_NAME > "A" OR c1.FIRST_NAME < "Z" AND c1.USERNAME = "guest" OR c1.LAST_NAME = "Doe" AND c1.FIRST_NAME = "Jane" OR c1.USERNAME > "admin" AND c1.IDENTIFIER < 500
