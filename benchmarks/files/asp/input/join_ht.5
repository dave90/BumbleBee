% ===== Query head =====
%qA(O,C,Item,Band,Tier,Carrier,Zone) ?

% ===== EDB (moderate, all binary) =====
orders(1..20, 1..40).        % (O,C)
lines(1..20, 1..30).         % (O,Item)
ship(1..20, 1..20).          % (O,Carrier)
price(1..30, 1..5).            % (Item,Band)
customer(1..40, 1..3).         % (C,Tier)
zone_o(1..20, 1..10).        % (O,Zone)
zone_c(1..40, 1..10).          % (C,Zone)
blocked_carrier(3). blocked_carrier(7). blocked_carrier(11).

% ===== Unary filters / projections (no joins) =====
hot_order(O) :- ship(O,Carrier), Carrier <= 15.
prio_item(Item) :- price(Item,Band), Band <= 3.
vip_cust(C) :- customer(C,Tier), Tier >= 2.

% ===== Final rule (and only place with joins) =====
qA(O,C,Item,Band,Tier,Carrier,Zone) :-
  hot_order(O),                      % unary prefilter
  prio_item(Item),                   % unary prefilter
  vip_cust(C),                       % unary prefilter
  orders(O,C),
  lines(O,Item),
  ship(O,Carrier),
  price(Item,Band),
  customer(C,Tier),
  zone_o(O,Zone),
  zone_c(C,Zone),
  Band <= Tier,                      % cross-attribute inequality
  Carrier < 15, O + C + Zone + Item + Band  + Tier + Carrier  < 10.