import os
import json
import subprocess
import sys
import time
import csv
import argparse
from datetime import datetime
from statistics import mean
from pathlib import Path
from glob import glob
import re

NUM_TRIES = 5
RESULTS_FOLDER = Path("results")

def run_command(command, output_path):
    """Runs a shell command and writes output to a file, returning the elapsed time."""
    with open(output_path, 'w') as out_file:
        start = time.perf_counter()
        subprocess.run(command, shell=True, stdout=out_file, stderr=subprocess.STDOUT)
        end = time.perf_counter()
    return end - start


def normalize_output(file_path):
    """Reads, strips, sorts, and deduplicates lines in a file."""
    if not os.path.exists(file_path):
        return set()
    with open(file_path, 'r') as f:
        lines = f.readlines()
    return set(sorted(line.strip() for line in lines if line.strip()))


def compare_outputs(file1, file2):
    """Compares normalized outputs of two files."""
    return normalize_output(file1) == normalize_output(file2)


def load_previous_results(config_name):
    """Finds the latest benchmark CSV for the config and loads average times."""
    pattern = RESULTS_FOLDER / f"{config_name}_benchmark_results_*.csv"
    files = sorted(glob(str(pattern)), reverse=True)
    if not files:
        return {}
    latest_file = files[0]
    with open(latest_file, newline='') as csvfile:
        reader = csv.DictReader(csvfile)
        return {row['test']: float(row['avg']) for row in reader}


def run_test_command_multiple_times(command, test_name, output_folder):
    """Runs the test command NUM_TRIES times and stores output."""
    times = []
    actual_output = output_folder / f"{test_name.replace(' ', '_')}.txt"

    for i in range(NUM_TRIES):
        print(f"  Try {i+1}/{NUM_TRIES}...")
        tmp_output = output_folder / f"tmp_{test_name.replace(' ', '_')}_{i}.txt"
        elapsed = run_command(command, tmp_output)
        times.append(elapsed)

        # Save final run output as the main output
        if i == NUM_TRIES - 1:
            tmp_output.rename(actual_output)

    return times, actual_output

def extract_query_predicates(input_file_path):
    """Extracts query predicate names from lines ending in ? and removes those lines."""
    query_predicates = set()
    filtered_lines = []

    with open(input_file_path, 'r') as f:
        for line in f:
            stripped = line.strip()
            if stripped.endswith('?'):
                # Extract predicate name before '('
                match = re.match(r'(\w+)\s*\(.*\)\s*\?', stripped)
                if match:
                    query_predicates.add(match.group(1))
            else:
                filtered_lines.append(line)

    return query_predicates, filtered_lines


def filter_output_by_predicates(output_file_path, predicates):
    """Filters output lines to keep only those matching query predicates."""
    if not os.path.exists(output_file_path):
        return

    with open(output_file_path, 'r') as f:
        lines = f.readlines()

    filtered_lines = [
        line for line in lines
        if any(line.strip().startswith(f"{pred}(") for pred in predicates)
    ]

    with open(output_file_path, 'w') as f:
        f.writelines(filtered_lines)

def run_comparison_commands(commands, test_name, expected_folder):
    """Runs comparison commands and stores expected output."""
    expected_output = expected_folder / f"{test_name.replace(' ', '_')}.txt"
    times = []

    for cmp_cmd in commands:
        print(f"  Running comparison: {cmp_cmd}")
        # Attempt to extract the file path from the command
        match = re.search(r"(\S+\.(lp|txt|in|input))", cmp_cmd)
        if not match:
            sys.exit(f"  ⚠️  Could not extract input file path from command: {cmp_cmd}")

        input_file = match.group(1)
        query_preds, cleaned_input_lines = extract_query_predicates(input_file)

        # Write cleaned input to a temporary file
        with tempfile.NamedTemporaryFile('w', delete=False, suffix=".lp") as tmp_input_file:
            tmp_input_file.writelines(cleaned_input_lines)
            tmp_input_path = tmp_input_file.name

        # Modify command to use the temp file instead
        cleaned_cmd = cmp_cmd.replace(input_file, tmp_input_path)
        # Run the modified command and capture output
        elapsed = run_command(cleaned_cmd, expected_output)
        times.append(elapsed)

        # Filter output to retain only the query predicates
        if query_preds:
            filter_output_by_predicates(expected_output, query_preds)

        # Clean up temporary file
        os.remove(tmp_input_path)

    return times, expected_output


def write_results_csv(config_name, results):
    """Writes results to a timestamped CSV file in the results folder."""
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    csv_filename = RESULTS_FOLDER / f"{config_name}_benchmark_results_{timestamp}.csv"
    with open(csv_filename, 'w', newline='') as csvfile:
        fieldnames = [
            "test", "avg", "min", "max",
            "delta_vs_cmp", "delta_vs_prev",
            "output_match"
        ]
        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
        writer.writeheader()
        for row in results:
            writer.writerow(row)
    return csv_filename


def process_test(test, output_folder, expected_folder, previous_results):
    """Handles the full process of running a test and comparison, returning result stats."""
    test_name = test["test"]
    command = test["command"]
    comparison_cmds = test.get("comparison", [])

    print(f"\nRunning test: {test_name}")

    # Run test command multiple times
    times, actual_output = run_test_command_multiple_times(command, test_name, output_folder)

    # Run comparison commands
    comparison_times, expected_output = run_comparison_commands(comparison_cmds, test_name, expected_folder)

    # Stats
    avg_time = mean(times)
    min_time = min(times)
    max_time = max(times)
    avg_cmp = mean(comparison_times) if comparison_times else 0.0
    delta_cmp = avg_time - avg_cmp
    delta_prev = avg_time - previous_results.get(test_name, 0.0)

    # Output verification
    if not compare_outputs(actual_output, expected_output):
        print(f"❌ Output mismatch in test: {test_name}")
        output_status = "mismatch"
    else:
        print(f"✅ Output match for: {test_name}")
        output_status = "match"

    return {
        "test": test_name,
        "avg": f"{avg_time:.4f}",
        "min": f"{min_time:.4f}",
        "max": f"{max_time:.4f}",
        "delta_vs_cmp": f"{delta_cmp:.4f}",
        "delta_vs_prev": f"{delta_prev:.4f}",
        "output_match": output_status
    }


def main():
    parser = argparse.ArgumentParser(description="Benchmark runner")
    parser.add_argument("config", help="Path to the config JSON file")
    args = parser.parse_args()

    config_path = Path(args.config)
    config_name = config_path.stem
    RESULTS_FOLDER.mkdir(parents=True, exist_ok=True)

    # Load config
    with open(config_path, 'r') as f:
        config = json.load(f)

    # Prepare folders
    output_folder = Path(config["output_folder"])
    expected_folder = Path(config["expected_folder"])
    output_folder.mkdir(parents=True, exist_ok=True)
    expected_folder.mkdir(parents=True, exist_ok=True)

    # Load previous results if available
    previous_results = load_previous_results(config_name)

    # Run all tests
    results = []
    for test in config["tests"]:
        result = process_test(test, output_folder, expected_folder, previous_results)
        results.append(result)

    # Save CSV
    csv_file = write_results_csv(config_name, results)
    print(f"\n✅ Benchmark complete. Results saved to: {csv_file}")


if __name__ == "__main__":
    main()
